@page "/"
<PageTitle>Currículo | Seu Nome</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4 text-center p-4 bg-light rounded-3 mb-4">
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" class="rounded-circle mb-3" width="120" />
            <h3>Albano de Souza</h3>
            <p class="text-muted">Professor de Matemática | Dev .NET em Formação</p>
        </div>
        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia { 
            Empresa = "Escola Municipal", 
            Cargo = "Professor de Matemática", 
            Inicio = "2015", 
            Descricao = "Atuação no ensino básico e gestão de turmas." 
        },
        new Experiencia { 
            Empresa = "Centro Universitário UNA", 
            Cargo = "Estudante de ADS", 
            Inicio = "2025", 
            Descricao = "Desenvolvimento de projetos em .NET, Java e IHC." 
        }
    };
}
